{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daytracker.local/schemas/ai/chat-request.json",
  "title": "Day Tracker AI chat request",
  "type": "object",
  "required": ["message"],
  "properties": {
    "schemaVersion": { "type": "integer" },
    "message": { "type": "string", "minLength": 1 },
    "viewDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "contextOptions": {
      "type": "object",
      "properties": {
        "includeIcal": { "type": "boolean" },
        "historyDays": { "type": "integer", "minimum": 0 }
      }
    },
    "taskContext": {
      "$ref": "task-context.schema.json",
      "description": "Day snapshot for the agent; see task-context.schema.json."
    },
    "contextFragments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dataRequestId", "queryId", "data"],
        "properties": {
          "dataRequestId": { "type": "string" },
          "queryId": { "type": "string" },
          "data": {}
        }
      }
    }
  },
  "additionalProperties": true
}
